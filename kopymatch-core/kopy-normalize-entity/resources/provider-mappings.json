        "total_trades": "tradeCount",
        "description": "bio"
      },
      "base_url": "https://www.okx.com/copy-trading/account/",
      "api_type": "rest"
    },
    "telegram": {
      "display_name": "Telegram",
      "field_mappings": {
        "roi": null,
        "followers": "members_count",
        "uid": "chat_id",
        "win_rate": null,
        "total_trades": null,
        "description": "description"
      },
      "base_url": "https://t.me/",
      "api_type": "bot_api"
    },
    "web": {
      "display_name": "Website",
      "field_mappings": {
        "roi": null,
        "followers": null,
        "uid": null,
        "win_rate": null,
        "total_trades": null,
        "description": null
      },
      "base_url": null,
      "api_type": "scraping"
    }
