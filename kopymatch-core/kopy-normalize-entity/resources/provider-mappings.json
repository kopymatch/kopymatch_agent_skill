        "followers": "copierCount",
        "uid": "leadPortfolioId",
        "win_rate": "winRate",
        "total_trades": "totalTrades",
        "description": "introduction"
      },
      "base_url": "https://www.binance.com/copy-trading/lead/",
      "api_type": "rest"
    },
    "okx": {
      "display_name": "OKX",
      "field_mappings": {
