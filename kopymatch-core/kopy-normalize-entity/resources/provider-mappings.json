  "id_format": "ent_{entity_type}_{provider}_{hash}",
  "normalization_rules": {
    "name": "lowercase → strip special chars → trim whitespace",
    "metrics": "convert to float, null if unavailable",
    "date": "ISO 8601 format"
  }
}
