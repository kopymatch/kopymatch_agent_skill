{
  "blocklist": {
    "version": "1.0.0",
    "updated_at": "2025-01-15",
    "description": "Danh sách domain và pattern bị chặn — không crawl các URL trong danh sách này.",
    "blocked_domains": [
      "localhost",
      "127.0.0.1",
      "0.0.0.0",
      "*.local",
      "*.internal"
    ],
    "blocked_patterns": [
      "*/admin/*",
      "*/login*",
      "*/auth/*",
      "*/api/internal/*"
    ],
    "rate_limits": {
      "default_delay_ms": 1000,
      "max_requests_per_minute": 30,
      "respect_robots_txt": true
    }
  }
}
